\endcsname
\catcode
\def
\edef
\let
\futurelet
\loop
\repeat
\href
\url
\includegraphics
\input
\include
\usepackage
\RequirePackage
\openin
\read
\newread
\closein
\openout
\write
\newwrite
\closeout
\write18
