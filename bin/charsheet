#!/usr/bin/env lua5.1

-- Read character-sheet YAML and emit various visualization aids


-- Note: Normally this code would be split among multiple modules:
--       validation infrastructure, sheet validation, rendering,
--       and so on.  But web deployment is so gnarly that I have
--       chosen to keep it all in one giant file.

------------------ classic print functions ---------------------
local stringf = string.format
local function eprintf(...) return io.stderr:write(stringf(...)) end
local function dief(...) eprintf(...); os.exit(1) end
local function errorf(...) error(stringf(...), 2) end
local function outf(out, ...)
  table.insert(out, stringf(...))
  return out
end

if arg[-1] == 'lua5.1' then
  local fd = io.open '/usr/bin/lua5.2'
  if fd then
    fd:close()
    local osx = require 'osx'
    table.insert(arg, 1, arg[0])
    table.insert(arg, 1, '/usr/bin/lua5.2')
    os.exit(osx.execv(arg) == 0 and 0 or 1)
  end
end


---- diagnostic output for option processing

local function commafy(t, andword, comma)
  if t == nil or #t == 0 then return '' end  -- ugly special case
  andword = andword or 'and'
  local comma_space = comma and comma .. ' ' or ', '
  local n = #t
  assert(n > 0, 'Empty list not handled correctly in string.commafy')
  if n == 1 then
    return t[1]
  elseif n == 2 then
    return table.concat { t[1], ' ', andword, ' ', t[2] }
  else
    local last = t[n]
    t[n] = andword .. ' ' .. t[n]
    local answer = table.concat(t, comma_space)
    t[n] = last
    return answer
  end
end

------------ basename and option processing ------------------------------------------

local basename = arg[0]:gsub('^.*/', '')
  -- basename determines behavior

local options = { -- specialized for different scripts
  charsheet = function(parser) return parser:numarg(1) end,
  gmsheet   = function(parser) return parser:minarg(1) end,
}
options.gmspells = options.gmsheet

if not options[basename] then
  local basenames = { }
  for k in pairs(options) do
    table.insert(basenames, stringf('`%s`', k))
  end
  table.sort(basenames)
  dief('%s: I expected to be called as %s.\n', arg[0], commafy(basenames, 'or'))
end

local fields = require 'flags'.parser()
  :output_file('output as o'):help('where to write if not stdout')
  :bool('fontable'):help('dump fontable keys and exit')
  :bool('verbose as v')
  :bool('nocolor'):help('disable color')
  :bool('quiet as q'):help('suppress stdout from pdflatex')
  :bool('strict'):help('halt on field validation errors (default: warn and continue)')
  :bool('standalone as s'):help('emit just definitions, not full file')
  :string('layout as t as l'):help('template for character sheet')
  :string('templates', os.getenv 'CHARSHEETS'
                    or os.getenv 'HOME' .. '/etc/dnd/resources/character-sheets/templates')
         :help('directory where character-sheet templates live')
  :wrap(assert(options[basename]))
  :string('class'):help('CLASS to use if none is supplied')
  :parse(arg)

local nothing = { }

local function table_or_nothing(v)
  if type(v) == 'table' then
    return v
  else
    return nothing
  end
end

local default_layouts = {
  charsheet = 'silverpine',
  gmsheet = 'gmsheet',
  gmspells = 'gmspells',
}

local default_layout =
  assert(default_layouts[basename], 'No default layout defined for ' .. basename)

local vprintf = fields.verbose and eprintf or function() end -- luacheck: no unused

local pdflatex =
  fields.quiet and 'pdflatex -interaction=nonstopmode -halt-on-error -file-line-error -no-shell-escape'
    or 'pdflatex -interaction=scrollmode -halt-on-error -no-shell-escape'

----------------- string utilities ---------------
--
-- likely for error messages

local function sq(s) -- string quote
  if type(s) ~= 'table' then
    return stringf('%q', s)
  else
    local quoted = { }
    for k, v in pairs(s) do
      quoted[k] = sq(v)
    end
    return quoted
  end
end

local function plural(count, what, theplural)
  if count == 1 then
    return what
  else
    return theplural or what .. 's'
  end
end

local function a(s)
  if s:find '^[aeiouAEIOU]' then
    return 'an ' .. s
  else
    return 'a ' .. s
  end
end


local isnull
local function friendly(v)
  if isnull(v) then
    return 'the YAML null (empty entry)'
  else
    return require 'inspect'.friendly(v)
  end
end




----------------- table utilities -----------------------------------------------

local function sorted_keys(t, lt)
  local u = { }
  for k in pairs(t) do table.insert(u, k) end
  table.sort(u, lt)
  return u
end

local function rmdups(xs, eq) -- remove duplicates from xs, return xs
  eq = eq or function(a, b) return a == b end
  local i = 1
  while i < #xs do
    if eq(xs[i+1], xs[i]) then
      table.remove(xs, i+1)
    else
      i = i + 1
    end
  end
  return xs
end

local function scalarvalues(list) -- iterator : value list -> value
  return coroutine.wrap(function()
      local function process(values)
        for _, value in pairs(values) do
          if type(value) == "table" then
            process(value)
          else
            coroutine.yield(value)
          end
        end
      end
      process(table_or_nothing(list))
    end)
end

local function tcopy(t)
  local u = { }
  for k, v in pairs(t) do
    u[k] = v
  end
  return setmetatable(u, getmetatable(t))
end

local function update(t, k, v)
  local u = tcopy(t)
  u[k] = v
  return u
end


----------------- function utilities ----------------

local function app1(f, arg1) -- partial application
  return function(...) return f(arg1, ...) end
end


----------------- yaml utilities --------------------

local lyaml  = require "lyaml"
function isnull(v) return v == lyaml.null end

local function false_yaml(v)
  return v == nil or v == false or v == 'false' or v == '0' or v == 0
end

assert(lyaml.dump)
local function image(v)
  return lyaml.dump({v}):gsub([[\]], [[\textbackslash{}]])
                        :gsub('\n', [[\emph{\scriptsize\textsc{nl}}]])
end

-- return a string with unbalanced {}, if any
local function unbalanced_yaml_string(doc)
  if type(doc) == 'string' then
    local d = doc:gsub('%b{}', '')
    if d:find '[{}]' then return doc end
  elseif type(doc) == 'table' then -- search values
    for _, v in pairs(doc) do
      local d = unbalanced_yaml_string(v)
      if d then return d end
    end
  end
end

assert(unbalanced_yaml_string([[\documentclass[10pt]{article}]]) == nil)
assert(unbalanced_yaml_string([[\documentclass[10pt]article}]]) ~= nil)
assert(unbalanced_yaml_string([[\documentclass[10pt]{article]]) ~= nil)
assert(unbalanced_yaml_string([[\documentclass[10pt]}article{]]) ~= nil)

assert(unbalanced_yaml_string { FOOT = "} ASDF {" } == "} ASDF {")


------------------------- infrastructure for validation errors

-- Global validation errors list
local global_validation_errors = {}

local curfile -- name of the file currently being validated


local context = { }

local verrorf -- save validation error
do
  local last_file_announced

  verrorf = function(fmt, ...)
    local msg = context.is(fmt)
                  and stringf('In %s, %s', tostring(fmt), stringf(...))
                   or stringf(fmt, ...)
    table.insert(global_validation_errors, (msg:gsub('(%s)"', '%1``'):gsub([["]], [['']])))
    if last_file_announced ~= curfile then
      eprintf('\nValidation error in %s: %s\n', curfile, msg)
      last_file_announced = curfile
    else
      eprintf('\nValidation error: %s\n', msg)
    end
  end
end

--------------------- sandboxing ------------------------

local bad_input_tex = [[
\documentclass[12pt]{article}
\def\lbrace{\char`\{}
\def\rbrace{\char`\}}
\begin{document}
A YAML file was rejected because some part of it contained
unbalanced braces, which is a security risk.  The offending
string was as follows:
\begin{quote}
\ttfamily
$BAD
\end{quote}
\end{document}
]]

local bad_control_sequences = { } -- do not allow in documents
do
  for cs in ([[
catcode
openout
write
makeatletter
\input
\include
\openin
\openout
\read
\write
