#!/usr/bin/env lua5.1
--------------------------------------------------------------------------
-- yaml-to-dndtex.lua   ‒  Convert character-sheet YAML to LaTeX macros
-- Usage:   lua yaml-to-dndtex.lua  file.yaml   > file.tex
--          cat file.yaml | lua yaml-to-dndtex.lua   > file.tex
--------------------------------------------------------------------------

------------------ classic print functions ---------------------
local stringf = string.format
local function eprintf(...) return io.stderr:write(stringf(...)) end
local function dief(...) eprintf(...); os.exit(1) end
local function errorf(...) error(stringf(...), 2) end
local function outf(out, ...)
  table.insert(out, stringf(...))
  return out
end

------------ basename and option processing ------------------------------------------

local basename = arg[0]:gsub('^.*/', '')
  -- basename determines behavior

local options = { -- specialized for different scripts
  charsheet = function(parser) return parser:numarg(1) end,
  gmsheet   = function(parser) return parser:minarg(1) end,
}
options.gmspells = options.gmsheet

local fields = require 'flags'.parser()
  :output_file('output as o'):help('where to write if not stdout')
  :bool('verbose as v')
  :bool('nocolor'):help('disable color')
  :bool('quiet as q'):help('suppress stdout from pdflatex')
  :bool('strict'):help('halt on field validation errors (default: warn and continue)')
  :bool('standalone as s'):help('emit just definitions, not full file')
  :string('layout as t as l'):help('template for character sheet')
  :string('templates', os.getenv 'CHARSHEETS' or '/home/nr/etc/dnd/resources/character-sheets/templates')
         :help('directory where character-sheet templates live')
  :wrap(assert(options[basename]))
  :parse(arg)

local nothing = { }

local default_layouts = {
  charsheet = 'silverpine',
  gmsheet = 'gmsheet',
  gmspells = 'gmspells',
}

local default_layout =
  assert(default_layouts[basename], 'No default layout defined for ' .. basename)

local vprintf = fields.verbose and eprintf or function() end

local pdflatex =
  fields.quiet and 'pdflatex -interaction=nonstopmode -halt-on-error -file-line-error -no-shell-escape'
    or 'pdflatex -interaction=scrollmode -halt-on-error -no-shell-escape'

----------------- string utilities ---------------
--
-- likely for error messages

local function sq(s)
  if type(s) ~= 'table' then
    return stringf('%q', s)
  else
    local quoted = { }
    for k, v in pairs(s) do
      quoted[k] = sq(v)
    end
    return quoted
  end
end

local function count(n, what, plural) -- luacheck: no unused
  if n == 1 then
    return stringf('one %s', what)
  elseif n == 0 then
    return stringf('no %s', plural or what .. 's')
  else
    return stringf('%d %s', n, plural or what .. 's')
  end
end

local function plural(count, what, theplural)
  if count == 1 then
    return what
  else
    return theplural or what .. 's'
  end
end

local function a(s)
  if s:find '^[aeiouAEIOU]' then
    return 'an ' .. s
  else
    return 'a ' .. s
  end
end


local isnull
local function friendly(v)
  if isnull(v) then
    return 'the YAML null (empty entry)'
  else
    return require 'inspect'.friendly(v)
  end
end




----------------- table utilities -----------------------------------------------

local function sorted_keys(t, lt)
  local u = { }
  for k in pairs(t) do table.insert(u, k) end
  table.sort(u, lt)
  return u
end

local function rmdups(xs, eq) -- remove duplicates from xs, return xs
  eq = eq or function(a, b) return a == b end
  local i = 1
  while i < #xs do
    if eq(xs[i+1], xs[i]) then
      table.remove(xs, i+1)
    else
      i = i + 1
    end
  end
  return xs
end

local function scalarvalues(list) -- iterator : value list -> value
  return coroutine.wrap(function()
      local function process(values)
        for _, value in pairs(values) do
          if type(value) == "table" then
            process(value)
          else
            coroutine.yield(value)
          end
        end
      end
      process(list)
    end)
end

-- Local recursive table equality comparison
local function table_eq(t1, t2)
  if t1 == t2 then
    return true
  elseif type(t1) ~= 'table' or type(t2) ~= 'table' then
    return false
  else
    for k, v in pairs(t1) do
      if not table_eq(v, t2[k]) then
        return false
      end
    end
    for k in pairs(t2) do
      if t1[k] == nil then
        return false
      end
    end
    return true
  end
end



local function commafy(t, andword, comma)
  if t == nil or #t == 0 then return '' end  -- ugly special case
  andword = andword or 'and'
  local comma_space = comma and comma .. ' ' or ', '
  local n = #t
  assert(n > 0, 'Empty list not handled correctly in string.commafy')
  if n == 1 then
    return t[1]
  elseif n == 2 then
    return table.concat { t[1], ' ', andword, ' ', t[2] }
  else
    local last = t[n]
    t[n] = andword .. ' ' .. t[n]
    local answer = table.concat(t, comma_space)
    t[n] = last
    return answer
  end
end

----------------- yaml utilities --------------------

local lyaml  = require "lyaml"
function isnull(v) return v == lyaml.null end

local function false_yaml(v)
  return v == nil or v == false or v == 'false' or v == '0' or v == 0
end

local function nonnull(v) if v ~= nil and v ~= lyaml.null then return v end end -- luacheck: no unused

assert(lyaml.dump)
local function image(v)
  return lyaml.dump({v}):gsub([[\]], [[\textbackslash{}]])
                        :gsub('\n', [[\emph{\scriptsize\textsc{nl}}]])
end

-- return a string with unbalanced {}, if any
local function unbalanced_yaml_string(doc)
  if type(doc) == 'string' then
    local d = doc:gsub('%b{}', '')
    if d:find '[{}]' then return doc end
  elseif type(doc) == 'table' then -- search values
    for _, v in pairs(doc) do
      local d = unbalanced_yaml_string(v)
      if d then return d end
    end
  end
end

assert(unbalanced_yaml_string([[\documentclass[10pt]{article}]]) == nil)
assert(unbalanced_yaml_string([[\documentclass[10pt]article}]]) ~= nil)
assert(unbalanced_yaml_string([[\documentclass[10pt]{article]]) ~= nil)
assert(unbalanced_yaml_string([[\documentclass[10pt]}article{]]) ~= nil)

assert(unbalanced_yaml_string { FOOT = "} ASDF {" } == "} ASDF {")


------------------------- infrastructure for validation errors

-- Global validation errors list
local global_validation_errors = {}

local curfile -- name of the file currently being validated

local verrorf -- save validation error
do
  local last_file_announced

  verrorf = function(...)
    local msg = stringf(...)
    table.insert(global_validation_errors, msg)
    if last_file_announced ~= curfile then
      eprintf('\nValidation error in %s: %s\n', curfile, msg)
      last_file_announced = curfile
    else
      eprintf('\nValidation error: %s\n', msg)
    end
  end
end


local bad_input_tex = [[
\documentclass[12pt]{article}
\def\lbrace{\char`\{}
\def\rbrace{\char`\}}
\begin{document}
A YAML file was rejected because some part of it contained
unbalanced braces, which is a security risk.  The offending
string was as follows:
\begin{quote}
\ttfamily
$BAD
\end{quote}
\end{document}
]]


--------------------- sandboxing

local bad_control_sequences = { } -- do not allow in documents
do
  for cs in ([[
catcode
openout
write
makeatletter
\input
\include
\openin
\openout
\read
\write
\immediate
\pdffilesize
\pdfmdfivesum
\pdfshellescape
\usepackage
\RequirePackage
\documentclass
\LoadClass
\bibliography
\bibliographystyle
\csname
\endcsname
\catcode
\def
\edef
\let
\futurelet
\loop
\repeat
\href
\url
\includegraphics
\input
\include
\usepackage
\RequirePackage
\openin
\read
\newread
\closein
\openout
\write
\newwrite
\closeout
\write18
\special
\shipout
\catcode
\globaldefs
\everyjob
\everypar
\everycr
\endlinechar
\lccode
\uccode
\sfcode
\mathcode
\delcode
\scantokens

\pdfobj
\pdfrefobj
\pdfannot
\pdfximage
\pdfcatalog
\pdfinfo
\pdfstartlink
\pdffilesize
\pdfmdfivesum
\pdffilemoddate
\pdffiledump

]]):gmatch [[%a+]] do
    bad_control_sequences['\\'..cs] = true
  end
end

local function sanitize_control_sequences(s)
  return (s:gsub([[%\%a+]],
            function(cs) if bad_control_sequences[cs] then
                return stringf([[\texttt{\textbackslash %s}]], cs:sub(2))
            end
  end))
end



--------- document (charsheet) utilities

local function named_things(doc) -- anything in MAGIC or FEATURES with a .name field
  return coroutine.wrap(function()
    for _, section in ipairs {'MAGIC', 'FEATURES'} do
      local things = doc[section] or nothing
      for _, thing in ipairs(things) do
        if thing.name then
          coroutine.yield(thing)
        end
      end
    end
  end)
end


------------------------------------------------------------------------
--
-- General-purpose validation predicates

local function wrap(p) -- on failure, produces the offending field (XXX name)
  return function(v)
    if p(v) then return true else return false, v end
  end
end

local inrange = function(lo, hi)
  return wrap(function (v)
    return tonumber(v) and tonumber(v) >= lo and tonumber(v) <= hi
  end)
end

assert(type(inrange(1,10)) == 'function')

local isnumber = inrange(-math.huge, math.huge) -- luacheck: no unused
local positive = inrange(1, math.huge)


local function anyvalue(_) -- luacheck: no unused
  return true
end

-- Higher-order validator functions

local function app1(f, arg1) -- partial application
  return function(...) return f(arg1, ...) end
end

local optional = function(p)
  return wrap(function (v)
    -- Handle YAML null, nil, and empty string as valid "empty" values
    if v == '' or v == nil or isnull(v) then
      return true
    else
      return p(v)
    end
  end)
end

assert(type(optional(positive)) == 'function')
assert(optional(positive)(nil))
assert(optional(positive)(3))
assert(not optional(positive)(0))

local function all(p, list)
  for _, v in ipairs(list) do
    local ok, msg = p(v)
    if not ok then
      return ok, msg
    end
  end
  return true
end

local function any(p, list)
  local ok, msg
  for _, v in ipairs(list) do
    ok, msg = p(v)
    if ok then
      return ok
    end
  end
  return false, msg
end

-------------------

-- predicate `can_be(tau1, tau2, ...)(v)` knows about type conversions

local can_be_tab = {
  string = wrap(function(v)
             return type(v) == 'string' or type(v) == 'number' or type(v) == 'boolean'
             end),
  number = wrap(function(v) return tonumber(v) end),
}
setmetatable(can_be_tab, { __index = function(_, t)
                                       return wrap(function(v) return type(v) == t end)
                           end})

local function can_be(...)
  local types = { ... }
  return function(v) return any(function(t) return can_be_tab[t](v) end, types) end
end

assert(can_be 'string'('hello'))
assert(can_be 'string'(7))

local function has(v, ...)
  if type(v) ~= 'table' then
    return false
  else
    for i = 1, select('#', ...) do
      if v[select(i, ...)] == nil then
        return false, select(i, ...)
      end
    end
    return true
  end
end

-----

local empty = wrap(function(v)
  return v == nil
      or type(v) == 'table' and next(v) == nil
      or type(v) == 'string' and not v:find '%S'
      or false
end)

local nonempty_string = wrap(function (v)
  return can_be 'string'(v) and tostring(v):find('%S')
end)

assert(nonempty_string 'Arborist')

local is_singleton_table = wrap(function(t)
  if type(t) == 'table' then
    local k = next(t)
    return k ~= nil and next(t, k) == nil
  end
end)

local islist = wrap(function(t)
  return type(t) == 'table' and (empty(t) or t[1] ~= nil)
end)

local function listof(predicate)
  return function(list)
    if not islist(list) then
      return false, list
    else
      local ok, msg = all(predicate, list)
      return ok, msg or "list contains invalid items"
    end
  end
end

------------ validation grammar

--[=[

  validator v ::= s[tring]
               |  n[number] [*[*[N]..[M]*]*]
               |  l[ist](v)
               |  name@v     -- name may be raw or with double quotes
               |  v*|*v
               |  (v)
               |  *{*{key[,]}*}*
               |  fname$v

  key         ::= [?]name[:v]   -- type defaults to text

------ LL grammar

  v ::=  alt {| alt}

  alt ::= string
       |  number
       |  list (v)
       |  name [@ v | $ v]
       |  { keys }
       |  ( v )

  <alnum>+ (
$ v
           | @ v
           |


]=]

local validators = { }

local show_parse = { } -- luacheck: no unused

local parse
do
  local inspect = require 'inspect'

  local function tokenize(s)
    local tokens = { }
    local init = s:find '%S'
    while init do
      local first, last, found  -- luacheck: no unused
      for _, pat in ipairs { '^(%.%.)', '^([^%w%d])', '^(%d+)', '(%a[%w%-]*)' } do
        first, last, found = s:find(pat, init)
        if found then
          table.insert(tokens, found)
          break
        end
      end
      if found then
        init = s:find('%S', last + 1)
      else
        dief('Unrecognized character at position %d in string %q', init, s)
      end
    end
    return tokens
  end

  function parse(semantics, s)

    local tokens = tokenize(s)
--    inspect.show{tokens = tokens}

    local function expected(context, wanted, i)
      if tokens[i] ~= wanted then
        errorf('Error parsing %s; expected %s, got %s at token %d', context, wanted,
             tokens[i] ~= nil and inspect.image(tokens[i]) or "end of stream", i)
      else
        vprintf('%s expected %s and found it at %d\n', context, wanted, i)
      end
    end

    local alts, alt, range, keys, key -- self == semantics

    alts = function(tokens, i)
      local alts = { }
      alts[1], i = alt(tokens, i)
      while tokens[i] == '|' do
        alts[#alts+1], i = alt(tokens, i + 1)
      end
      vprintf('found one or more balidators before %d (%s)\n', i, tostring(tokens[i]))
      if #alts > 1 then
        return semantics:alts(alts), i
      else
        return alts[1], i
      end
    end

    key = function(tokens, i)
      if tokens[i] == '*' then
        return semantics:any_key(), i + 1
      else
        local optional = tokens[i] == '?'
        if optional then i = i + 1 end
        local nameparts = { }
        while tokens[i]:find '%w' do
          table.insert(nameparts, tokens[i])
          i = i + 1
        end
        local validator
        if tokens[i] == ':' then
          validator, i = alts(tokens, i + 1)
        end
        vprintf('found a key ending before token %d (%s)\n', i, tostring(tokens[i]))
        return semantics:key(table.concat(nameparts, ' '), optional, validator), i
      end
    end

    keys = function(tokens, i)
      local keys = { }
      keys[1], i = key(tokens, i)
      vprintf('first key ends before token %d (%s)\n', i, tostring(tokens[i]))
      while tokens[i] == ',' do
        if tokens[i+1] == '}' then
          i = i + 1
          break
        else
          local thekey, j = key(tokens, i + 1)
          vprintf('key ends before token %d (%s)\n', j, tostring(tokens[j]))
          table.insert(keys, thekey)
          i = j
        end
      end
      expected('table keys', '}', i)
      return semantics:table(keys), i + 1
    end



    alt = function(tokens, i)
      local next = tokens[i]
      if not next then
        errorf('Ran out of tokens parsing validator: %s', inspect.image(tokens))
      elseif next == 's' or next == 'string' then
        return semantics:string(), i + 1
      elseif next == 'n' or next == 'number' then
        local rg, j = range(tokens, i + 1)
        return semantics:number(rg), j
      elseif next == 'l' or next == 'list' then
        if tokens[i+1] == '{' then
          local v, j = keys(tokens, i + 2)
          return semantics.list(v), j
        else
          expected('list type', '(', i + 1)
          local v, j = alts(tokens, i + 2)
          expected('end of list type', ')', j)
          return semantics:list(v), j + 1
        end
      elseif next == '{' then
        return keys(tokens, i + 1)
      elseif next == '(' then
        local v, j = alts(tokens, i + 1)
        expected('parenthesized validator', ')', j)
        return v, j + 1
      elseif next:find '%w' then -- good name
        local marker = tokens[i+1]
        if marker == '@' then
          local v, j = alt(tokens, i+2)
          return semantics:named(next, v), j
        elseif marker == '$' then
          local v, j = alt(tokens, i+2)
          return semantics:validate(next, v), j
        else
          errorf('Unrecognized validation type %q', next)
        end
      else
        errorf('Validation parser found unknown token %q at position %d in %s',
             next, i, inspect.image(tokens))
      end
    end

    range = function(tokens, i)
      if tokens[i] == '[' then
        i = i + 1
        local lo, hi
        if tonumber(tokens[i]) then
          lo, i = tonumber(tokens[i]), i + 1
        end
        expected('numeric range', '..', i)
        i = i + 1
        if tonumber(tokens[i]) then
          hi, i = tonumber(tokens[i]), i + 1
        end
        expected('numeric range', ']', i)
        i = i + 1
        return { lo = lo, hi = hi }, i
      else
        -- No '[' range: consume nothing but still return the index, so the
        -- parsing-function contract (value, i) holds and callers don't get a
        -- nil i (was leaving alt's number branch returning a nil index).
        return nil, i
      end
    end

    return (alts(tokenize(s), 1))

  end


  local function stringf(...)
    local thing = string.format(...)
    vprintf('Semantics received %s\n', thing)
    return thing
  end

  function show_parse:number(rg)
    if rg then
      return stringf('a number in range %s..%s',
                     rg.lo and tostring(rg.lo) or '',
                     rg.hi and tostring(rg.hi) or '')
    else
      return stringf('a number')
    end
  end

  function show_parse:key(name, optional, v)
    return stringf('%s%s%s', optional and 'maybe ' or '', name, v and ', ' .. v or '')
  end

  function show_parse:any_key()
    return 'or any other key'
  end

  function show_parse:table(keys)
    return stringf('a table with these keys: { %s }', table.concat(keys, '; '))
  end

  function show_parse:string()
    return 'a string'
  end

  function show_parse:list(v)
    return stringf('a list in which each element is %s', v)
  end

  function show_parse:named(name, v)
    return stringf('%s, which is %s', a(name), v)
  end

  function show_parse:alts(alts)
    return stringf('(Any of %s)', table.concat(alts, ' OR '))
  end

  function show_parse:validate(f, v)
    return stringf('%s validated by function %s', v, f)
  end

end


local vfactory = { }

do
  -- key       : { name : string, optional : bool, validator = v }
  -- validator : object with methods and fields
  --    self:validate(context, value) optionally returns normalized value
  --    self:mine(value) returns bool
  --    self.what : string

  local function out_of_range(n, rg)
    if rg then
      return rg.lo and n < rg.lo or rg.hi and n > rg.hi
    end
  end

  local function missing(context, wanted, found)
    verrorf('In %s, was looking for %s, but found %s', context, wanted, friendly(found))
  end

  function vfactory:number(rg)
    local range_string = ''
    if rg then
      if rg.lo and rg.hi then
        range_string = stringf(' in the range %d..%d', rg.lo, rg.hi)
      elseif rg.lo then
        range_string = stringf(' at least %d', rg.lo)
      elseif rg.hi then
        range_string = stringf(' at most %d', rg.hi)
      end
    end

    local what = stringf('a number%s', range_string)

    return {
      validate = function(_, context, v)
        if not tonumber(v) or out_of_range(v, rg) then
          missing(context, what, v)
        else
          return tonumber(v)
        end
      end,
      mine = function(_, v) return can_be 'number'(v) end,
      what = what,
    }
  end

  local any_key = { } -- unique value

  local text = {
    validate = function(_, context, v)
      if not can_be 'string' (v) then
        missing(context, 'text', v)
      else
        return tostring(v)
      end
    end,
    mine = function(_, v) return can_be 'string'(v) end,
    what = 'text',
  }

  function vfactory:key(name, optional, v)
    return {name = name, optional = optional, validator = v}
  end

  function vfactory:any_key()
    return any_key
  end

  function vfactory:table(keys)
    local required, optional, other = { }, { }, false
    for _, key in ipairs(keys) do
      if key == any_key then
        other = true
      elseif key.optional then
        table.insert(optional, key.name)
      else
        table.insert(required, key.name)
      end
    end
    local also
    local wanted =
      #required > 0 and stringf('a table with %s %s', plural(#required, 'key'), commafy(sq(required)))
                     or 'a table without any required keys'
    if #optional > 0 then
      also = stringf('%s %s', plural(#optional, 'key'), commafy(sq(optional)))
    end
    if other and not also then
      if #required > 0 then
        wanted = stringf('%s, and possibly other keys', wanted)
      else
        wanted = stringf('%s but allowing any key you wish to include', wanted)
      end
    elseif other and also then
      if #required > 0 then
        wanted = stringf('%s, plus optionally %s, and possibly other keys', wanted, also)
      else
        wanted = stringf('a table with optional %s, plus any other key you wish to include', also)
      end
    elseif also then
      local conjunction = #required > 0 and 'and also' or 'but'
      wanted = stringf('%s %s optionally %s', wanted, conjunction, also)
    end

    local acceptable
    if not other then
      acceptable = { }
      for _, k in ipairs(keys) do
        acceptable[k.name] = true
      end
    end

    local function has_key(v, keys)
      return any(function(k) return v[k] ~= nil end, keys)
    end

    return {
      what = wanted,
      mine = function(_, v) return type(v) == 'table' and has_key(v, required) end,
      validate = function(_, context, v)
        if type(v) ~= 'table' then
          missing(context, wanted, v)
        else
          local myname = v.name or v.NAME
          local mycontext =
               myname and type(myname) == 'string' and stringf('%q, which is %s', myname, context)
            or context
          local omitted = { }
          for _, key in ipairs(keys) do
            if key == any_key then
              -- do nothing
            elseif v[key.name] == nil and not key.optional then
              table.insert(omitted, sq(key.name))
            elseif v[key.name] ~= nil then
              local val = key.validator or text
              local u = val:validate(stringf('field %s of %s', key.name, mycontext), v[key.name])
              if u ~= nil then
                v[key.name] = u
              end
            end
          end
          if #omitted == 1 then
            verrorf('In %s, required key %s is missing', mycontext, omitted[1])
          elseif #omitted > 0 then
            verrorf('In %s, required keys %s are missing', mycontext, commafy(omitted))
          end

          if not other then
            local unexpected = { }
            for k in pairs(v) do
              if not acceptable[k] then
                table.insert(unexpected, type(k) == 'string' and sq(k) or tostring(k))
              end
            end
            if #unexpected > 0 then
              verrorf('In %s, found unexpected %s %s',
                      mycontext, plural(#unexpected, 'key'), commafy(unexpected))
            end
          end
        end
      end,
    }
  end

  function vfactory:string()
    return text
  end

  function vfactory:list(element)
    return {
      what = stringf('a list of %s', element.what),
      mine = function(_, v) return type(v) == 'table' and (v[1] ~= nil or next(v) == nil) end,
      validate = function(_, context, v)
        if type(v) ~= 'table' or next(v) ~= nil and not v[1] then
          missing(context, 'a list', v)
        else
          for i, e in ipairs(v) do
            element:validate(stringf('element %d of %s', i, context), e)
          end
        end
      end,
    }
  end

  function vfactory:named(name, validator)
    return {
      mine = function(_, v) return validator:mine(v) end,
      what = stringf('%s, which is %s', a(name), validator.what),
      validate = function(_, context, v)
        return validator:validate(stringf('%s, which is %s', a(name), context), v)
      end,
    }
  end

  function vfactory:alts(alts)
    local whatnames = { }
    for _, alt in ipairs(alts) do
      table.insert(whatnames, alt.what)
    end
    whatnames = commafy(whatnames, 'or')

    return { mine = function(_, v) return any(function(alt) return alt:mine(v) end, alts) end,
             what = whatnames,
             validate = function(_, context, v)
               for _, alt in ipairs(alts) do
                 if alt:mine(v) then
                   return alt:validate(context, v)
                 end
               end
               -- or maybe just the first? XXX
               verrorf("In %s, expected %s, but didn't find %s of those things.  Found %s",
                       context, whatnames, #alts == 2 and 'either' or 'any', friendly(v))
             end,
    }
  end

  function vfactory:validate(f, validator)
    return {
      mine = function(_, v) return validator:mine(v) end,
      what = validator.what,
      validate = function(_, context, v)
        local bad = #global_validation_errors
        validator:validate(context, v)
        if #global_validation_errors == bad then
          assert(validators[f], 'No validation function named ' .. f)(context, v)
        end
      end,
    }
  end

end




--print(parse(show_parse, '{level:n[0..9],?slots:n}'))

local function new_validate(context, doc, validation)
  parse(vfactory, validation):validate(context, doc)
end


