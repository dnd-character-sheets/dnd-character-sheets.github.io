vnames.etable = 'categorized list of equipment'

function validators.docfont(_, v)
  if not v:find '^1[012]pt$' then
    verrorf('The DOCUMENT FONT must be 10pt, 11pt, or 12pt; found %q', v)
  end
end

function validators.attack(context, v)
  if not empty(v['AMMO COUNT']) and empty(v['AMMO TYPE']) then
    verrorf('In %s, AMMO COUNT is specified without an AMMO TYPE', context)
  end
end

local function description(thing)
  return thing.description or thing.long or thing.abbrev
end

function validators.described(context, v)
  if not description(v) then
    verrorf('In %s, %q has no description', context, v.name)
  end
end

function validators.level(context, v)
  if v.level == 0 and v.slots then
    verrorf('In %s, spec for cantrips (level 0) included slots, but cantrips have no slots',
            context)
  elseif v.level > 0 and not v.slots then
    verrorf('In %s, spec for level %d is missing its slot count', context, v.level)
  end
end

function validators.eqline(context, v)
  local cat = v:match '^(.-):'
  if cat and not equipment.good_category(cat) then
    verrorf('In %s, equipment line %q uses an unknown category %q', context, v, cat)
  end
end


function validators.nonempty(context, v)
  if empty(v) then
    verrorf('In %s, expected data but found %s', context, friendly(v))
  end
end



-- Validation function
function validators.sheet(context, sheet)
  if not empty(sheet.WIS) and empty(sheet['PASSIVE PERCEPTION']) then
    verrorf('In %s, WIS is present but PASSIVE PERCEPTION is missing', context)
  end
end


-------------------------------------------------------------------------
--
-- Extending and changing the bare YAML

--------------------------------------------------------------------------

-- semantic predicates

local function same_values(v1, v2) -- same strings, or strings denoting the same number
  local s1, s2 = tostring(v1), tostring(v2)
  return v1 == v2 or
         s1:find '^%d+$' and s2 == '+' .. s1 or
         s2:find '^%d+$' and s1 == '+' .. s2
end


-- D&D info and knowledge

local abilities =
  { STR = true, DEX = true, CON = true, INT = true, WIS = true, CHA = true }

local saving_throw_proficiencies = {
  Barbarian = { "Strength", "Constitution" },
  Bard      = { "Dexterity", "Charisma" },
  Cleric    = { "Wisdom", "Charisma" },
  Druid     = { "Intelligence", "Wisdom" },
  Fighter   = { "Strength", "Constitution" },
  Monk      = { "Strength", "Dexterity" },
  Paladin   = { "Wisdom", "Charisma" },
  Ranger    = { "Strength", "Dexterity" },
  Rogue     = { "Dexterity", "Intelligence" },
  Sorcerer  = { "Constitution", "Charisma" },
  Warlock   = { "Wisdom", "Charisma" },
  Wizard    = { "Intelligence", "Wisdom" }
}

local casting_ability = {
  Bard      = 'CHA',
  Cleric    = 'WIS',
  Druid     = 'WIS',
  Paladin   = 'CHA',
  Ranger    = 'WIS',
  Sorcerer  = 'CHA',
  Warlock   = 'CHA',
  Wizard    = 'INT',
}

local function ability_modifier(score)
  return math.floor((score - 10) / 2)
end

local function proficiency_bonus(level)
  return 2 + math.floor((level - 1) / 4)
end

local function passive_skill(sheet, stat, proficiency, expertise)
  local prof_bonus = proficiency_bonus(sheet.LEVEL)
  local skill_bonus = proficiency and (expertise and 2 * prof_bonus or prof_bonus) or 0
  return 10 + ability_modifier(sheet[stat] or 10) + skill_bonus
end

local function spell_attack_modifier(level, mod)
  return proficiency_bonus(level) + mod
end

local function spell_dc(level, mod)
  return 8 + proficiency_bonus(level) + mod
end


-- Colon conversion
--
-- YAML interprets, e.g., `Language: Common` as a singleton table,
-- but we want it to be a string.

local function convert_colon_tables(v)
  -- returns converted version of v, while converting any internal
  -- colon tables
  if islist(v) then
    for i, e in ipairs(v) do
      v[i] = convert_colon_tables(e)
    end
    return v
  elseif not is_singleton_table(v) then
    return v
  else
    local k, e = next(v)
    if k == 'proficiencies_skip' and tostring(e) == 'true' then
      return [[\profskip{}]]
    elseif type(k) == 'string' then
      if isnull(e) then -- singleton table
        return stringf('%s:', k)
      elseif can_be 'string'(e) then
        return stringf('%s: %s', k, tostring(e))
      else
        v[k] = convert_colon_tables(e)
      end
    end
    return v
  end
  assert(false) -- luacheck: ignore
end

--- Add tags to the names of spells

local magic_markers = {
  concentration = 'C',
  ritual = 'R',
  bonus = 'B',
  reaction = 'Rx',
  domain  = 'D',
}

local function add_magic_markers(name, thing)
  if type(name) ~= 'string' then
    return name
  else
    local tags = name:match '%b[]'
    if tags and tags:find '^.[%u,x]+.$' then
      return name
    else
      tags = { }
      for property, tag in pairs(magic_markers) do
        if not false_yaml(thing[property]) then
          table.insert(tags, tag)
        end
      end
      if #tags > 0 then
        table.sort(tags)
        return stringf('%s [%s]', name, table.concat(tags, ','))
      else
        return name
      end
    end
  end
end







local function string_note(thing)
  local n = thing['GM note']
  if type(n) == 'string' then
    return n
  end
end

local function skill_p_e(sheet, skill) -- return proficiency and expertise
  local skill = skill:lower()
  for _, t
  in ipairs { sheet.PROFICIENCIES or nothing, sheet['SECONDARY PROFICIENCIES'] or nothing }
  do
    for p in scalarvalues(t) do
      if type(p) == 'string' and p:lower():find(skill) then
        return true, p:find('[E]', 1, true)
      end
    end
  end
end

local function extend(sheet)

  ----------- options  ---------------
  if fields.nocolor then
    sheet.COLOR = false
  end

  -- confirm existing value or set new one
  local function update(field, value) -- checks for consistency
    local v = sheet[field]
    if v and tostring(v):find '%S' and not same_values(v, value) then
      verrorf('Value %s computed as %s, but input says %s\n',
              field, tostring(value), tostring(v))
    elseif not tostring(v):find '^%+' then
      sheet[field] = value
    end
  end

  ------------------ class and level -----------------

  local class = assert(sheet.CLASS)
  sheet.LEVEL = sheet.LEVEL or 1
  local level = sheet.LEVEL

  ---------- calculated fields -------------

  do -- saving-throw profs
    for _, prof in ipairs(saving_throw_proficiencies[class] or nothing) do
      update(stringf('%s SAVING', prof:sub(1,3):upper()), true)
    end
  end

  update('PROFICIENCY BONUS', proficiency_bonus(sheet.LEVEL))


  do -- spellcasting ability, modifier, DC
    local casting = casting_ability[class] or sheet['SPELLCASTING ABILITY']
    if casting and tonumber(sheet[casting]) then
      update('SPELLCASTING ABILITY', casting)
      local mod = ability_modifier(tonumber(sheet[casting]))
      update('SPELL DC', spell_dc(level, mod))
      update('SPELL ATTACK MODIFIER', stringf('%+d', spell_attack_modifier(level, mod)))
    end
  end

  do   -- passive skills
    local function set_passive_skill(stat, skill)
      update(stringf('PASSIVE %s', skill:upper()),
             passive_skill(sheet, stat, skill_p_e(sheet, skill)))
    end

    set_passive_skill('WIS', 'Perception')
    set_passive_skill('WIS', 'Insight')
  end

  ---------------- improvements to display --------------

  do -- put save abilities in \textsc
    for thing in named_things(sheet) do
      if type(thing.save) == 'string' and abilities[thing.save:upper()] then
        thing.save = stringf([[\textsc{%s}]], thing.save:lower())
      end
    end
  end

  -- add info markers to spell names
  for thing in named_things(sheet) do
    if thing.markers ~= false then
      thing.name = add_magic_markers(thing.name, thing)
    end
  end


  --------------------- reactions and bonus actions for GM sheet -------------
  do -- find bonus actions, for GM sheet
    local function stripname(s)
      return s:gsub([[\rlap%b{}]], function(t) return t:sub(7,-2) end)
              :gsub([[\footnotesize%s*]], '')
              :gsub('%s*%b[]', '')
              :gsub('%s+$', '')
    end

    local function things_with(field)
      local things = { }
      for thing in named_things(sheet) do
        if thing[field] then
          local name = stripname(thing.name)
          local description =
            string_note(thing) and stringf('%s [%s]', name, string_note(thing)) or name
          table.insert(things, stringf([[\%s{%s}]], field, description))
        end
      end
      return table.concat(things, '\\relax\n  ')
    end

    sheet['BONUS ACTIONS'] = things_with 'bonus'
    sheet['REACTIONS'] = things_with 'reaction'
  end

  return sheet
end

----------------------------------- normalization --------------------------

local function heuristic_category(_)
  return 'SLOTTED ITEMS'
end

local function normalize_equipment(eq)
  if not eq[1] then -- either empty or already in table form
    return eq
  else
    local category = equipment.category
    local normal =
      setmetatable({}, { __index = function(t, k) local u = {} t[k] = u return u end })

    local in_category = false
    for _, line in ipairs(eq) do
      if type(line) == 'string' and line:find '%S' then -- counting on validation to show error
        if not line:find '^%s*%-%s' then
          in_category = false
        end
        local block_header = line:match("^(.+):$")
        if block_header then
          in_category = category(block_header) or heuristic_category(block_header)
          -- heuristic is used only if block header is invalid, which will have been flagged
        elseif in_category then
          table.insert(normal[in_category], (line:gsub('^%s*%-%s+', ''):gsub('%s+$', '')))
        elseif line:find '^%S.*:' then -- inline "category: item"
          local cat, item = assert(line:match '^(.-)%s*:%s*(.*)$')
          table.insert(normal[category(cat) or heuristic_category(item)], item)
        else
          table.insert(normal[heuristic_category(line)], line)
        end
      end
    end
    return setmetatable(normal, nil)
  end
end





local function normalize(sheet)
  sheet.EQUIPMENT = sheet.EQUIPMENT and normalize_equipment(sheet.EQUIPMENT)

  for _, rec in ipairs(sheet.ATTACKS or nothing) do
    if type(rec.ATTACK) == 'number' then
      rec.ATTACK = stringf('%+d', rec.ATTACK)
    end
  end
end


