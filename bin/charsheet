  ["shield"] = "SHIELDS",
  ["heavy armor"] = "HEAVY ARMOR",
  ["heavy armour"] = "HEAVY ARMOR",
  ["normal armor"] = "MEDIUM ARMOR",
  ["normal armour"] = "MEDIUM ARMOR",
  ["medium armor"] = "MEDIUM ARMOR",
  ["medium armour"] = "MEDIUM ARMOR",
  ["light armor"] = "LIGHT ARMOR",
  ["light armour"] = "LIGHT ARMOR",
  ["heavy item"] = "HEAVY ITEMS",
  ["slotted item"] = "SLOTTED ITEMS",
  ["free item"] = "SMALL ITEMS",
  ["small item"] = "SMALL ITEMS",
  ["stored item"] = "STORED ITEMS",
  ["stored"] = "STORED ITEMS",
}

equipment.category_order = {
 "SHIELDS",
 "LIGHT WEAPONS",
 "NORMAL WEAPONS",
 "HEAVY WEAPONS",
 "LIGHT ARMOR",
 "MEDIUM ARMOR",
 "HEAVY ARMOR",
 "HEAVY ITEMS",
 "SLOTTED ITEMS",
 "SMALL ITEMS",
 "STORED ITEMS"
}

function equipment.good_category(c)
  c = c:lower():gsub('s$', '')
  if equipment.canonical_category[c] then
    return c
  end
end

function equipment.category(s)
  local function strip_s(s)
    if s:sub(-1) == 's' then
      return s:sub(1, -2)
    else
      return s
    end
  end

  return equipment.canonical_category[strip_s(s:lower())]
end




do -- set equipment.tablespec
  local catspecs = { }
  local function catspec(category)
    return stringf('?^%s:(s|list(s))', category)
  end
  for category in pairs(equipment.canonical_category) do
    table.insert(catspecs, catspec(category))
    table.insert(catspecs, catspec(category .. 's'))
  end
  equipment.tablespec = stringf('{%s}', table.concat(catspecs, ', '))
end

