if fields.fontable then
  local methods = setmetatable({}, {__index = function() return function() return false end end })
  function methods:key(name, props, _)
    if props.fontable then
      io.stdout:write(name, '\n')
    end
    return name
  end
  parse(methods, doc_validation)
  os.exit(0)
