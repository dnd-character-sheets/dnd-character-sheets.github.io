--------------------------------------------------------------------------
---
--- Help for LaTeX output

local escape_tex

do

  local map = {
  --  ["\\"] = [[\textbackslash{}]],
  --  ["{"]  = [[\{]],
  --  ["}"]  = [[\}]],
    [' '] = '~',
    ["&"]  = [[\&]],
    ["%"]  = [[\%]],
    ["$"]  = [[\$]],
    ["#"]  = [[\#]],
    ["_"]  = [[\_]],
    ["~"]  = [[\textasciitilde{}]],
    ["^"]  = [[\textasciicircum{}]],
  }

  escape_tex = function (s)
    if isnull(s) then
      return ''
    else
      return (tostring(s):gsub("[\\&%%$#_{}~^]", map)
                         :gsub('([%s%d])%-(%d)', [[%1\textminus%2]])
                         :gsub("−", [[\textminus{}]])
      )
    end
  end
end

local function do_not_escape(s) return tostring(s) end

--- rendering, start here
---
---

local render = { }
local function setDND(k, v)
  local fontbase = k:match('(.*) FONT$')
  if fontbase then
    return stringf([[\setDNDfont{%s}{%s}]], fontbase, do_not_escape(v))
  else
    return stringf([[\setDND{%s}{%s}]], k, do_not_escape(v))
  end
end
render.string  = setDND
render.number  = setDND
render.boolean = setDND

function render.ipairs(render, vs, separator)
  local items = {}
  for _, v in ipairs(vs) do
    table.insert(items, render(v))
  end
  return table.concat(items, separator or "\n")
end

function render.pairs(render, t, separator)
  local items = {}
  for k, v in pairs(t) do
    table.insert(items, render(k, v))
  end
  return table.concat(items, separator or "\n")
end

function render.sorted_pairs(render, t, separator)
  local keys = { }
  for k in pairs(t) do
    table.insert(keys, k)
  end
  table.sort(keys)
  local items = {}
  for _, k in ipairs(keys) do
    table.insert(items, render(k, t[k]))
  end
  return table.concat(items, separator or "\n")
end

function render.ATTACKS(k, v)
  return setDND(k, render.ipairs(render.keys, v))
end

function render.keys(v)
  return stringf([[\dndkeys{%s}]], render.sorted_pairs(render.eqbinding, v, ','))
end

function render.eqbinding(k, v)
  return stringf("%s={%s}", do_not_escape(k), do_not_escape(v))
end


function render.described(thing) -- describe a named thing
  local suffix =
    (thing.attack or thing.offense or thing.offensive or thing.save or thing.enemy)
    and 'Colored{attacks}' or ''
  return stringf([[\described%s{%s}{%s}]], suffix,
    do_not_escape(thing.name or ''), do_not_escape(description(thing) or ''))
end

function render.FEATURES(k, v)
  return setDND(k, render.ipairs(render.described, v))
end

function render.MAGIC(k, v)
  return setDND(k, render.ipairs(render.spell, v))
end

function render.spell(thing)
  if thing.level then
    return stringf([[\spellslevellabel{%s}{%d}]], thing.level, thing.slots or 0)
  else
    return render.described(thing)
  end
end


function render.PROFICIENCIES(k, v)
  return setDND(k, render.ipairs(render.proficiency, v))
end

render['SECONDARY PROFICIENCIES'] = render.PROFICIENCIES

function render.item(s)
  return stringf([[\item %s]], s)
end

function render.proficiency(elem)
  if type(elem) == 'string' then
    return render.item(elem)
  elseif empty(elem) then
    return [[\profskip{}]]
  else
    local groups = { }
    for category, profs in pairs(elem) do
      outf(groups, [[\item %s: \begin{innerlist}%s\end{innerlist}]], category,
           render.ipairs(render.proficiency, profs))
    end
    return table.concat(groups, '\n')
  end
end


equipment.category_order = {
 "SHIELDS",
 "LIGHT WEAPONS",
 "NORMAL WEAPONS",
 "HEAVY WEAPONS",
 "LIGHT ARMOR",
 "MEDIUM ARMOR",
 "HEAVY ARMOR",
 "HEAVY ITEMS",
 "SLOTTED ITEMS",
 "SMALL ITEMS",
 "STORED ITEMS"
}

function render.EQUIPMENT(_, eq)
  local encumbrance = { }

  for category, items in pairs(eq) do -- record for encumbrance
    for _, item in ipairs(items) do
      table.insert(encumbrance, render.encumbrance(category, item))
    end
  end

  local flatlist = { }
  for _, category in ipairs(equipment.category_order) do
    if eq[category] then -- don't want to insert a blank line into flatlist
      table.insert(flatlist, render.ipairs(render.item, eq[category]))
    end
  end

  return table.concat(encumbrance, '\n') .. setDND('EQUIPMENT', table.concat(flatlist, '\n'))
end

function render.encumbrance(category, item)
  assert(category ~= 'UNCATEGORIZED')
  local stones = item:match '%((%d+) stone%s?%)'
  local optional = stones and stringf('[%d]', 10 * tonumber(stones)) or ''
  return stringf([[\addDNDitem%s{%s}{%s}]], optional, category:gsub('&', '+'), item)
end



-- Helper function to visualize table structure for debugging
local function visualize_table(t, indent) -- luacheck: no unused
  indent = indent or 0
  local spaces = string.rep("  ", indent)
  local result = {}
  for k, v in pairs(t) do
    if type(v) == "table" then
      table.insert(result, spaces .. tostring(k) .. " = {")
      table.insert(result, visualize_table(v, indent + 1))
      table.insert(result, spaces .. "}")
    else
      table.insert(result, spaces .. tostring(k) .. " = " .. tostring(v))
    end
  end
  return table.concat(result, "\n")
end

-- Convert structured equipment back to string list format
local function unparse_equipment_structure(structured_equipment)
  local lines = {}

  -- Helper to capitalize first letter of each word
  local function capitalize(s)
    return s:gsub("(%a)([%w_']*)", function(first, rest)
      return first:upper() .. rest:lower()
    end)
  end

  -- Helper to get singular form and proper capitalization
  local function format_category_name(category)
    return capitalize(category:lower():gsub("s$", ""))
  end

  for category, items in pairs(structured_equipment) do
    if type(items) == "table" then
      if #items == 1 then
        -- Single item: use inline format
        local formatted_category = format_category_name(category)
        table.insert(lines, formatted_category .. ": " .. items[1])
      else
        -- Multiple items or empty: use block format
        local formatted_category = format_category_name(category)
        table.insert(lines, formatted_category .. "s:")
        for _, item in ipairs(items) do
          table.insert(lines, "- " .. item)
        end
      end
    end
  end

  return lines
end

render['VALIDATION ERRORS'] = function(k, v)
  return setDND(k, render.ipairs(render.item, v))
end


local function validate_equipment_parsing(_)
  eprintf 'equipment parsing not validated \n'
end


-- Round-trip validation function
function validators.equipment(_, equipment)
  validate_equipment_parsing(equipment)
end


---------------------------------------------------------------------------
-- 4. Convert a single YAML mapping to LaTeX lines
---------------------------------------------------------------------------

--for k, v in pairs(render) do
--  render[k] = function(...) eprintf('CALL rander.%s %s\n', k, require 'inspect'.image { ... })
--                            return v(...)
--  end
--end


do -- defend against invalid inputs breaking rendering
  for k, v in pairs(render) do
    if type(v) == 'function' then
      local function finish(ok, ...)
        if ok then return ...
        else return stringf('render.%s failed because of invalid input', k)
        end
      end
      render[k] = function(...) return finish(pcall(v, ...)) end
    end
  end
end



local function render_sheet (map)
  local lines = {}

  for _, k in ipairs(sorted_keys(map)) do -- emit in predictable order
    local v = map[k]
    local t = type(v)
    local renderer = render[k] or render[t] or function() return '% UNIMP ' .. k end
    table.insert(lines, (renderer)(k, v))
  end
  return table.concat(lines, "\n")
end

---------------------------------------------------------------------------
-- 5. Entry point
---------------------------------------------------------------------------
local function slurp(filename)
  if filename == '-' or filename == '.' or not filename then
    return io.stdin:read("*a")
  else
    local f = assert(io.open(filename, "r"))
    local txt = f:read("*a"); f:close(); return txt
  end
end




local function preprocess(sheet)
  for _, f in ipairs { 'EQUIPMENT', 'PROFICIENCIES', 'SECONDARY PROFICIENCIES',
                       'AGE', 'DESCRIPTION', 'MOTIVATION', 'SPECIALTY', 'CLASS', 'GM NOTES',
                     }
  do
    sheet[f] = convert_colon_tables(sheet[f])
  end

  -- work around parsing in javascript
  for _, f in ipairs {'PROFICIENCIES', 'SECONDARY PROFICIENCIES'}
  do
    local t = sheet[f]
    if islist(t) then
      for i, l in ipairs (t) do
        if l == '' then
          t[i] = lyaml.null
        end
      end
    end
  end

  return sheet
end



local function contents(filename)
  local f, msg = io.open(filename, 'r')
  if not f then return f, msg end
  local s, msg = f:read '*a'
  if not s then return s, string.format('%s: %s', filename, msg) end
  f:close()
  return s
end

local function set_contents(filename, s)
  local f, msg = io.open(filename, 'w')
  if not f then return f, msg end
  local s = assert(f:write(s))
  f:close()
  return s or true
end

local quote_me = '[^%w%+%-%=%@%_%/%.%:]' -- easier to complement what doesn't need quotes
local function shell_quote(s)
  if s:find(quote_me) or s == '' then
    return "'" .. string.gsub(s, "'", [['"'"']]) .. "'"
  else
    return s
  end
end


local function double_percents(s)
  return (s:gsub('%%', '%%%%'))
end

local function fill_template(assignments, layout)
  local pathname = stringf('%s/%s.tex', fields.templates, layout)
  local template, msg = contents(pathname)
  if not template then
    eprintf('%s\n', msg)
    os.exit(1)
  else
    local images = { 'splash.png', 'merman.pdf', 'splash-nocolor.png' }
    local filled = template:gsub('\n[ \t]*\\input%b{}', '\n' .. double_percents(assignments))
    for _, image in ipairs(images) do
      local pattern = image:gsub('%W', '%%%1')
      local bracketed = stringf('{%s/%s}', fields.templates, image)
      filled = filled:gsub('%{' .. pattern .. '%}', bracketed)
    end
    return filled
  end
end



local runlatex = [=[
pdflatex=$PDFLATEX
output="$OUTPUT"

dir="$(mktemp -d)"
trap "rm -rf $dir" 0
tee /tmp/debug > "$dir/sheet.tex"
$pdflatex -output-directory "$dir" "$dir/sheet.tex"
rc=$?

if [[ $rc != 0 ]]; then
  exit $rc
fi

if [[ -r "$dir/sheet.pdf" ]]; then
  cp "$dir/sheet.pdf" "$output"
else
  rm -f "$output"
  exit 1
fi
]=]

local function wrap_latex(latex, layout, font)
  local output = fields.standalone and latex or fill_template(latex, layout)
  if font then
    output = output:gsub([[\documentclass.-%d+pt.-article]],
      function(line1)
        return (line1:gsub('%d+pt', font))
      end)
  end
  return output
end

local function process(output)
  if not fields.output then
    io.stdout:write(output, '\n')
  elseif fields.output:find '%.tex$' then
    set_contents(fields.output, output)
  elseif fields.output:find '%.pdf$' then
    local command = runlatex:gsub('%$PDFLATEX', shell_quote(pdflatex))
                            :gsub('%$OUTPUT', shell_quote(fields.output))
    local fd = assert(io.popen(stringf('bash -c %s', shell_quote(command)), 'w'))
    fd:write(output)
    local ok, termination, code = fd:close()
    if not ok then
      os.exit(termination == 'exit' and code or 1)
    end
    do -- check success
      local fd = io.open(fields.output)
      if fd then
        fd:close()
      else
        os.exit(1)
      end
    end
--
--    local tex = fields.output:gsub('%.pdf$', '.tex')
--    set_contents(tex, output)
--    local rc = runf('%s -output-directory %s %s',
--                    pdflatex, osquote(dirname(fields.output)), osquote(tex))
--    if rc ~= 0 then
--      os.exit(rc)
--    end
  end
end

local function sheet_of_file(pathname)
  curfile = pathname
  local yaml_text = slurp(pathname)
  local ok, sheet, msg = pcall(lyaml.load, yaml_text)
  if not ok or type(sheet) ~= 'table' then
    eprintf('charsheet load failed %s\n', (not ok and sheet) or msg or 'YAML loaded as string')
    os.exit(1)
  end
  assert(type(sheet) == 'table')

  do -- look for unbalanced braces (security risk)
    local bad = unbalanced_yaml_string(sheet)
    if bad then
      local replace =
        { ['{'] = [[\lbrace{}]], ['}'] = [[\rbrace{}]], ['\\'] = [[\textbackslash{}]] }
      local display = bad:gsub([=[[{}\]]=], replace)
      process(bad_input_tex:gsub("%$BAD", display))
      return
    end
  end

  -- Validate document before processing
  preprocess(sheet)
  validate(pathname, sheet, sheet_validation)
  extend(sheet)
  normalize(sheet)
  if #global_validation_errors > 0 then
    if fields.strict then
      eprintf("Validation failed in strict mode. Exiting.\n")
      os.exit(1)
    else
      eprintf("Validation warnings encountered. Continuing...\n")
      -- In non-strict mode, accumulate validation errors in the document
      sheet['VALIDATION ERRORS'] = global_validation_errors
    end
  end
  return sheet, sheet['DOCUMENT FONT']
end

local scripts = { }
function scripts.charsheet(arg)
  local sheet, font = sheet_of_file(arg[1])
  local layout = fields.layout or sheet.LAYOUT or default_layout
  local latex = sanitize_control_sequences(escape_tex(render_sheet(sheet)))
  process(wrap_latex(latex, layout, font))
end

local function plus_newline(s)
  return s .. '\n'
end

local function namelt (t1, t2)
  if t1.name == t2.name then
    return t1.abbrev and not t2.abbrev
  else
    return t1.name < t2.name
  end
end
local function nameeq (t1, t2) return t1.name == t2.name end

function scripts.gmsheet(arg)
  local latexes = { }
  local docs = { }
  local font
  for i, playerfile in ipairs(arg) do
    local sheet, f = sheet_of_file(playerfile)
    font = font or f
    table.insert(docs, sheet)
    local defs = sanitize_control_sequences(escape_tex(render_sheet(sheet)))
    table.insert(latexes, stringf(plus_newline [[\setDNDplayer{%d}{%s}]], i, defs))
  end

  do -- durable effects
    local function dname(thing)
      local s = thing.name
      local concentration = ''
      if thing.concentration or s:find('%b[]') and s:find('%AC%A') then
        concentration = [[ \C]]
      end
      return s:gsub('%s+%b[]', ''):gsub([[\rlap%s*%b{}]], ''):gsub(',%s*$', '') ..
             concentration
    end

    local durables = { }
    for _, sheet in ipairs(docs) do
      for thing in named_things(sheet) do
        if thing.duration then
          table.insert(durables, thing)
        end
      end
    end
    table.sort(durables, namelt)
    rmdups(durables, nameeq)
    local code = {}
    local function outdurable(thing)
      local duration = stringf([[\?%s]], thing.duration):gsub([[%\%?(%d%d)]], '%1')
      outf(code, plus_newline [[  \durable{%s}{%s}%%]], dname(thing), duration)
    end
    local function outdurables(lo, hi)
      outf(code, '%%\n {%%\n')
      for i = lo, hi do
        outdurable(durables[i])
      end
      outf(code, ' }')
    end
    do
      outf(code, [[\def\durables{]])
      local mid = math.ceil(#durables/2.0)
      outdurables(1, mid)
      outdurables(mid+1, #durables)
      outf(code, '}%% \\durables\n')
    end
    do
      outf(code, [[\def\durablestriple{]])
      local second = math.ceil(#durables/3.0)
      outdurables(1, second)
      local third = second + math.ceil((#durables-second) / 2.0)
      outdurables(second+1, third)
      outdurables(third+1, #durables)
      outf(code, '}%% triple\n')
    end

    table.insert(latexes, table.concat(code, ''))
  end

  do -- attack spells
    local attacks = { }
    for _, sheet in ipairs(docs) do
      for spell in named_things(sheet) do
        if spell.attack then
          table.insert(attacks, spell)
        end
      end
    end
    table.sort(attacks, namelt)
    for i, attack in ipairs(attacks) do
      attacks[i] = stringf([[\attack{%s}]], attack.name)
    end
    rmdups(attacks)
    table.insert(latexes,
                 stringf([[\def\spellattacks]] .. '{%%\n  %s%%\n}%%\n',
                         table.concat(attacks, '%\n  ')))
  end

  local function first_initial(sheet)
    local first = (sheet['CHARACTER NAME'] or 'Nobody'):match '%u'
    return first
  end

  local function firstname(sheet)
    local first = (sheet['CHARACTER NAME'] or 'Nobody'):match '%u[%a%-]+' or ''
    if first == '' then
      first = sheet.CLASS or '?'
    end
    return first
  end

  do -- saving-throw spells
    local savedocs = { } -- map spell name to list of docs
    local savestats = { } -- and to stat
    for _, sheet in ipairs(docs) do
      for spell in named_things(sheet) do
        if spell.save then
          local name = spell.name:gsub('%s*%b[]', '')
          savestats[name] = spell.save
          savedocs[name] = savedocs[name] or {}
          table.insert(savedocs[name], sheet)
        end
      end
    end
    for i, spellname in ipairs(sorted_keys(savedocs)) do
      local dcs = { }
      for _, sheet in ipairs(savedocs[spellname]) do
        local dc = tonumber(sheet['SPELL DC'])
        dcs[dc] = dcs[dc] or { }
        table.insert(dcs[dc], sheet)
      end
      local suffix
      if is_singleton_table(dcs) then
        suffix = stringf([[\textsc{%s}~%d]], savestats[spellname], (next(dcs)))
      else
        local dclist = { }
        for _, sheet in ipairs(savedocs[spellname]) do
          local s = stringf('%s,~%d', first_initial(sheet), tonumber(sheet['SPELL DC']))
          table.insert(dclist, s)
        end
        suffix =
          stringf([[\textsc{%s}: %s]], savestats[spellname], table.concat(dclist, '; '))
      end
      savedocs[i] = stringf([[\savespell{%s}{%s}]], spellname, suffix)
    end
    table.insert(latexes,
                 stringf([[\def\spellsaves]] .. '{%%\n  %s%%\n}%%\n',
                         table.concat(savedocs, '%\n  ')))
  end

  do -- passives
    local function gt(v1, v2) return v1 > v2 end
    for _, skill in ipairs { 'Perception', 'Insight' } do
      local players = { } -- map skill to list of players
      for _, sheet in ipairs(docs) do
        local passive_skill = tonumber(assert(sheet['PASSIVE ' .. skill:upper()]))
        players[passive_skill] = players[passive_skill] or { }
        table.insert(players[passive_skill], firstname(sheet))
      end
      local rows = { }
      for _, passive in ipairs(sorted_keys(players, gt)) do
        local ps = players[passive]
        table.sort(ps)
        local cmd = stringf([[\skillrow{%d}{%s}]], passive, table.concat(ps, ', '))
        table.insert(rows, cmd)
      end
      local latex = stringf([[\setpassive{%s}{%%]] .. '\n  %s%%\n}\n',
                            skill, table.concat(rows, '%\n  '))
      table.insert(latexes, latex)
    end
  end

  local layout = fields.layout or default_layout
  process(wrap_latex(table.concat(latexes, '\n'), layout, font))
end

function scripts.gmspells(arg)
  local docs = { }
  local font
  for _, path in ipairs(arg) do
    local sheet, f = sheet_of_file(path)
    font = font or f
    table.insert(docs, sheet)
  end
  local spells = { } -- need a way to identify features
  for _, sheet in ipairs(docs) do
    for _, spell in ipairs(sheet.MAGIC or nothing) do
      if spell.name then
        table.insert(spells, spell)
      end
    end
    for _, feature in ipairs(sheet.FEATURES or nothing) do
      local inserted = nil
      if feature['GM note'] ~= false then
        table.insert(spells, feature)
        inserted = 'YES'
      end
      if feature.name:find 'Mask' or feature.name:find 'Ability' then
      require 'inspect'.show { name = feature.name, note = feature['GM note'], inserted = inserted }
      end
    end
  end

  local latexes = { }
  local function latexf(...) table.insert(latexes, stringf(...)) end
  table.sort(spells, namelt)
  rmdups(spells, nameeq)
  for _, spell in ipairs(spells) do
    local note = string_note(spell) and stringf([[ \emph{%s}]], spell['GM note']) or ''
    local description = spell.abbrev or spell.description or spell.long
    local name = escape_tex(spell.name)
    if spell.components then
      name = stringf([[%s {\footnotesize\upshape [%s]}]], name, spell.components)
    end
    latexf([[\spell{%s}{%s%s}]], name, escape_tex(description), note)
  end

  local layout = fields.layout or default_layout
  process(wrap_latex(table.concat(latexes, '\n'), layout, font))
end

if fields.fontable then
  local methods = setmetatable({}, {__index = function() return function() return false end end })
  function methods:key(name, props, _)
    if props.fontable then
      io.stdout:write(name, '\n')
    end
    return name
  end
  parse(methods, sheet_validation)
elseif scripts[basename] then
  scripts[basename](arg)
else
  dief('%s: I expected to be called as `charsheet`, `gmsheet`, or `gmspells`.\n')
end

