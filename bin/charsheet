local doc_validation = ([[
{ *,
  ?ATTACKS:attacks@list(
     attack${ NAME, ATTACK, DAMAGE, TYPE, ?RANGE, ?AMMO TYPE, ?AMMO COUNT:n, ?NOTES}),
  ?FEATURES:list(feature@{name,description}),
  ?MAGIC:list(spell$spell@{MAGICPROPNAMES}
             |level-spec@{level:n[0..9],?slots:n[1..]}
             ),

