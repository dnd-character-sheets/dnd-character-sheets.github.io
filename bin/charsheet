-------------------- Normalizing YAML ---------------------------------

-- Colon conversion
--
-- YAML interprets, e.g., `Language: Common` as a singleton table,
-- but we want it to be a string.

local function convert_colon_tables(v)
  -- returns converted version of v, while converting any internal
  -- colon tables
  if islist(v) then
    for i, e in ipairs(v) do
      v[i] = convert_colon_tables(e)
    end
    return v
  elseif not is_singleton_table(v) then
    return v
  else
    local k, e = next(v)
    if k == 'proficiencies_skip' and tostring(e) == 'true' then
      return [[\profskip{}]]
    elseif type(k) == 'string' then
      if isnull(e) then -- singleton table
        return stringf('%s:', k)
      elseif can_be 'string'(e) then
        return stringf('%s: %s', k, tostring(e))
      else
        v[k] = convert_colon_tables(e)
      end
    end
    return v
  end
  assert(false) -- luacheck: ignore
end


--------------------------------------------------------------------------
--
-- Validating FEATURES and MAGIC
--
-- Two kinds of entries: { name: ..., description: ... } and spell_slots


local function report_bad_properties(what, entry, props)
  for k in pairs(entry) do
    if not props[k] then
      verrorf('%s has unknown property %q', what, k)
    end
  end
end


local function validate_magic_entry(entry)
  if isnull(entry) then
    -- skip it
  elseif has(entry, 'level') then
    -- Level entry
    if not inrange(0, 9)(entry.level) then
      verrorf('spell level designation is %q; expected a number from 1 to 9', image(entry.level))
    elseif tonumber(entry.level) == 0 then
      if entry.slots then
        verrorf('cantrips (level 0) list %s slots; expected no slots', tostring(entry.slots))
      end
    elseif not entry.slots then
      verrorf("spell marker for level %d doesn't include a slot count", tonumber(entry.level))
    elseif tonumber(entry.slots) <= 0 then
      verrorf("spell marker for level %d doesn't provide any slots", tonumber(entry.level))
    end
  elseif has(entry, 'name') then
    if valid_named_thing('magic spell', entry) then
      if not nonempty_string(entry.description) then
        verrorf('spell %s does not have a description', tostring(entry.name))
      end
      report_bad_properties(stringf('spell %s', entry.name), entry, magic_property)
    end
  else
    verrorf('Expected a spell description or a level designation; got MAGIC entry %s',
            friendly(entry))
  end
end

