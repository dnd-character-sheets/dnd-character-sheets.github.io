#!/usr/bin/env lua5.1
-- Convert Angry Monster Creator JSON to YAML format for character sheets
-- Direct field mapping without calculating derived values

local cjson = require('cjson')
local yaml = require('lyaml')

-- Convert JSON monster to YAML structure
local function convert_monster(json_mon)
    local mon = {}

    -- Basic info
    mon.NAME = json_mon.name
    mon.SIZE = json_mon.size and json_mon.size:upper() or nil
    mon["MONSTER TYPE"] = json_mon.type
    if json_mon.tag and json_mon.tag ~= "" then
        mon["MONSTER TYPE"] = mon["MONSTER TYPE"] .. " (" .. json_mon.tag .. ")"
    end
    mon.ALIGNMENT = json_mon.alignment
    mon.TIER = json_mon.tier
    mon.ORGANIZATION = json_mon.org

    -- Ability scores
    mon.STR = tonumber(json_mon.strPoints)
    mon.DEX = tonumber(json_mon.dexPoints)
    mon.CON = tonumber(json_mon.conPoints)
    mon.INT = tonumber(json_mon.intPoints)
    mon.WIS = tonumber(json_mon.wisPoints)
    mon.CHA = tonumber(json_mon.chaPoints)

    -- Hit points
    if json_mon.avgHP then
        mon["MAX HP"] = json_mon.avgHP
    end

    -- Speed (base speed always present)
    mon.SPEED = json_mon.speed
    -- Additional movement modes (table-driven to reduce repetition)
    local movement_modes = {
        {json_field = "burrowSpeed", yaml_field = "BURROW"},
        {json_field = "climbSpeed", yaml_field = "CLIMB"},
        {json_field = "flySpeed", yaml_field = "FLY"},
        {json_field = "swimSpeed", yaml_field = "SWIM"}
    }
    for _, mode in ipairs(movement_modes) do
        local speed = tonumber(json_mon[mode.json_field])
        if speed and speed > 0 then
            mon[mode.yaml_field] = json_mon[mode.json_field]
        end
    end

    -- Senses (table-driven to reduce repetition)
    local senses = {}
    local sense_types = {
        {json_field = "darkvision", name = "Darkvision"},
        {json_field = "blindsight", name = "Blindsight"},
        {json_field = "tremorsense", name = "Tremorsense"},
        {json_field = "truesight", name = "Truesight"}
    }
    for _, sense in ipairs(sense_types) do
        local range = tonumber(json_mon[sense.json_field])
        if range and range > 0 then
            table.insert(senses, {sense.name, json_mon[sense.json_field] .. " ft."})
        end
    end
    if #senses > 0 then
        mon.SENSES = senses
    end

    -- Languages
    if json_mon.languages and #json_mon.languages > 0 then
        local langs = {}
        for _, lang in ipairs(json_mon.languages) do
            table.insert(langs, lang.name)
        end
        mon.LANGUAGES = langs
    end

    -- Skills (just names and stats, bonuses calculated elsewhere)
    if json_mon.skills and #json_mon.skills > 0 then
        local skills = {}
        for _, skill in ipairs(json_mon.skills) do
            -- Store skill name and which ability it uses
            table.insert(skills, {skill.name, skill.stat})
        end
        mon.SKILLS = skills
    end

    -- Damage types (table-driven to reduce repetition)
    if json_mon.damagetypes and #json_mon.damagetypes > 0 then
        local damage_type_mappings = {
            {json_type = "vulnerable", yaml_field = "VULNERABILITIES"},
            {json_type = "resistant", yaml_field = "RESISTANCES"},
            {json_type = "immune", yaml_field = "IMMUNITIES"}
        }
        for _, mapping in ipairs(damage_type_mappings) do
            local damages = {}
            for _, dt in ipairs(json_mon.damagetypes) do
                if dt.type == mapping.json_type then
                    table.insert(damages, dt.name)
                end
            end
            if #damages > 0 then
                mon[mapping.yaml_field] = damages
            end
        end
    end

    -- DPR (damage per round)
    if json_mon.avgDMG then
        mon.DPR = json_mon.avgDMG
    elseif json_mon.dpr then
        mon.DPR = json_mon.dpr
    end

    -- Save DC (from mdc field)
    if json_mon.mdc then
        mon.DC = tonumber(json_mon.mdc)
    end

    -- Simple action lists (table-driven to reduce repetition)
    local simple_action_lists = {
        {json_field = "abilities", yaml_field = "TRAITS"},
        {json_field = "reactions", yaml_field = "REACTIONS"},
        {json_field = "legendaries", yaml_field = "LEGENDARY ACTIONS"},
        {json_field = "villains", yaml_field = "VILLAIN ACTIONS"}
    }
    for _, list_config in ipairs(simple_action_lists) do
        local json_list = json_mon[list_config.json_field]
        if json_list and #json_list > 0 then
            local items = {}
            for _, item in ipairs(json_list) do
                table.insert(items, {name = item.name, description = item.desc})
            end
            mon[list_config.yaml_field] = items
        end
    end

    -- ACTIONS
    if json_mon.actions and #json_mon.actions > 0 then
        local actions = {}
        local multiattack = nil
        for _, action in ipairs(json_mon.actions) do
            if action.name == "Multiattack" then
                multiattack = {name = action.name, description = action.desc}
            else
                local act = {name = action.name, description = action.desc}
                if action.atkbonus then
                    act["ATTACK BONUS"] = action.atkbonus
                end
                table.insert(actions, act)
            end
        end
        if multiattack then
            mon.MULTIATTACK = {multiattack}
        end
        if #actions > 0 then
            mon.ATTACKS = actions
        end
    end

    return mon
end

-- Main program
local function main()
    local input_file = arg[1]

    if not input_file then
        io.stderr:write("Usage: " .. arg[0] .. " <input.monster>\n")
        os.exit(1)
    end

    -- Read JSON
    local f = io.open(input_file, "r")
    if not f then
        io.stderr:write("Error: Cannot open file: " .. input_file .. "\n")
        os.exit(1)
    end
    local json_text = f:read("*all")
    f:close()

    -- Remove trailing commas (common in JavaScript but invalid in JSON)
    -- Pattern: comma followed by optional whitespace and then closing bracket/brace
    json_text = json_text:gsub(",%s*([%]%}])", "%1")

    -- Parse JSON
    local ok, json_mon = pcall(cjson.decode, json_text)
    if not ok then
        io.stderr:write("Error: Failed to parse JSON: " .. json_mon .. "\n")
        os.exit(1)
    end

    -- Convert to YAML structure
    local mon = convert_monster(json_mon)

    -- Output YAML
    local yaml_text = yaml.dump({mon})
    print(yaml_text)
end

main()
