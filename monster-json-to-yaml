#!/usr/bin/env lua5.1
-- Convert Angry Monster Creator JSON to YAML format for character sheets
-- Direct field mapping without calculating derived values

local stringf = string.format
local cjson = require('cjson')
local yaml = require('lyaml')

-- Create a proxy table that tracks which keys are accessed from the original JSON
-- Returns: proxy table, original table, accessed keys table
local function make_tracking_proxy(original)
    local proxy = {}
    local accessed = {}

    local mt = {
        __index = function(t, k)
            accessed[k] = true
            local v = original[k]
            rawset(t, k, v)
            return v
        end
    }

    setmetatable(proxy, mt)
    return proxy, original, accessed
end

-- Check for unaccessed keys in original JSON and error if any found
local function check_unaccessed_keys(original, accessed, input_file)
    local unaccessed = {}
    for k, _ in pairs(original) do
        if not accessed[k] then
            table.insert(unaccessed, k)
        end
    end

    if #unaccessed > 0 then
        table.sort(unaccessed)
        io.stderr:write("Error: Unaccessed JSON keys in " .. input_file .. ":\n")
        for _, k in ipairs(unaccessed) do
            io.stderr:write("  " .. k .. "\n")
        end
        os.exit(1)
    end
end

-- Helper function to ignore fields we don't convert
local function ignore(x) end

-- Convert JSON monster to YAML structure
local function convert_monster(json_mon)
    local mon = {}

    -- Basic info
    mon.NAME = json_mon.name
    mon.SIZE = json_mon.size
    mon["MONSTER TYPE"] = json_mon.type
    if json_mon.tag and json_mon.tag ~= "" then
        mon["MONSTER TYPE"] = stringf("%s (%s)", mon["MONSTER TYPE"], json_mon.tag)
    end
    mon.ALIGNMENT = json_mon.alignment
    mon.TIER = json_mon.tier
    mon.ORGANIZATION = json_mon.org

    -- Ability scores
    mon.STR = json_mon.strPoints
    mon.DEX = json_mon.dexPoints
    mon.CON = json_mon.conPoints
    mon.INT = json_mon.intPoints
    mon.WIS = json_mon.wisPoints
    mon.CHA = json_mon.chaPoints

    mon["MAX HP"] = json_mon.avgHP
    mon["HIT DICE"] = json_mon.hitDice and string.format("d%d", json_mon.hitDice)
    mon.SPEED = json_mon.speedDesc ~= "" and json_mon.speedDesc -- narrative

    -- SPEEDS table (numeric values)
    local speeds = {}
    local movement_modes = {
        {json_field = "speed", yaml_field = "WALK"},
        {json_field = "burrowSpeed", yaml_field = "BURROW"},
        {json_field = "climbSpeed", yaml_field = "CLIMB"},
        {json_field = "flySpeed", yaml_field = "FLY"},
        {json_field = "swimSpeed", yaml_field = "SWIM"}
    }
    for _, mode in ipairs(movement_modes) do
        local speed_val = tonumber(json_mon[mode.json_field])
        if speed_val and speed_val > 0 then
            speeds[mode.yaml_field] = json_mon[mode.json_field]
        end
    end

    -- Add hover flag if applicable
    speeds.HOVER = json_mon.hover or nil
    mon.SPEEDS = next(speeds) and speeds

    -- Senses (table-driven to reduce repetition)
    local senses = {}
    local sense_types = {
        {json_field = "darkvision", name = "Darkvision"},
        {json_field = "blindsight", name = "Blindsight"},
        {json_field = "tremorsense", name = "Tremorsense"},
        {json_field = "truesight", name = "Truesight"}
    }
    for _, sense in ipairs(sense_types) do
        local range = tonumber(json_mon[sense.json_field])
        if range and range > 0 then
            table.insert(senses, {sense.name, json_mon[sense.json_field] .. " ft."})
        end
    end

    -- Add telepathy to senses if present
    local telepathy_range = tonumber(json_mon.telepathy)
    if telepathy_range and telepathy_range > 0 then
        table.insert(senses, {"Telepathy", telepathy_range .. " ft."})
    end

    mon.SENSES = #senses > 0 and senses or nil
    mon.BLIND = json_mon.blind or nil      -- Blind flag (only if true)

    -- Languages
    local langs = json_mon.languages and #json_mon.languages > 0 and {}
    if langs then
        for _, lang in ipairs(json_mon.languages) do
            table.insert(langs, lang.name)
        end
        mon.LANGUAGES = langs
    end

    -- Skills (just names and stats, bonuses calculated elsewhere)
    if json_mon.skills and #json_mon.skills > 0 then
        local skills = {}
        for _, skill in ipairs(json_mon.skills) do
            -- Store skill name and which ability it uses
            table.insert(skills, {skill.name, skill.stat})
        end
        mon.SKILLS = skills
    end

    -- Saving throw proficiencies
    if json_mon.sthrows and #json_mon.sthrows > 0 then
        local saves = {}
        for _, save in ipairs(json_mon.sthrows) do
            table.insert(saves, save.name)
        end
        mon["SAVE PROFICIENCIES"] = saves
    end

    -- Damage types (table-driven to reduce repetition)
    if json_mon.damagetypes and #json_mon.damagetypes > 0 then
        local damage_type_mappings = {
            {json_type = "vulnerable", yaml_field = "VULNERABILITIES"},
            {json_type = "resistant", yaml_field = "RESISTANCES"},
            {json_type = "immune", yaml_field = "IMMUNITIES"}
        }
        for _, mapping in ipairs(damage_type_mappings) do
            local damages = {}
            for _, dt in ipairs(json_mon.damagetypes) do
                if dt.type == mapping.json_type then
                    table.insert(damages, dt.name)
                end
            end
            if #damages > 0 then
                mon[mapping.yaml_field] = damages
            end
        end
    end

    -- Condition immunities
    if json_mon.conditions and #json_mon.conditions > 0 then
        local conds = {}
        for _, cond in ipairs(json_mon.conditions) do
            table.insert(conds, cond.name)
        end
        mon["CONDITION IMMUNITIES"] = conds
    end

    mon.ARMOR = json_mon.otherArmorDesc ~= "" and json_mon.otherArmorDesc
    mon["AC ADJUSTMENT"] = json_mon.acadj ~= 0 and json_mon.acadj
    mon.DPR = json_mon.avgDMG

    -- Threat value
    if json_mon.threatval then
        mon.THREAT = json_mon.threatval
    end

    -- Assert threatadj is 0
    if json_mon.threatadj and json_mon.threatadj ~= 0 then
        io.stderr:write("Error: threatadj is " .. tostring(json_mon.threatadj) .. ", expected 0\n")
        os.exit(1)
    end

    -- THREATS table (stat threat levels)
    local threat_values = {poor = -1, average = 0, good = 1}
    local function threat(name)
        return name and assert(threat_values[name])
    end

    mon.THREATS = {
        AC = threat(json_mon.armorName),
        ["ATTACK BONUS"] = threat(json_mon.atkName),
        DPR = threat(json_mon.dprName),
        ["MAX HP"] = threat(json_mon.hpName),
        DC = threat(json_mon.stName),
    }

    -- MORALE table
    local morale = {
      THRESHOLD = json_mon.mthresh,
      TRIGGER = json_mon.mtrig ~= "" and json_mon.mtrig,
      TYPE =  json_mon.mtype ~= "" and json_mon.mtype,
      DC =  json_mon.mdc,
    }
    mon.MORALE = next(morale) and morale

    -- Bonus actions
    if json_mon.bonuses and #json_mon.bonuses > 0 then
        local bonus_actions = {}
        for _, bonus in ipairs(json_mon.bonuses) do
            table.insert(bonus_actions, {name = bonus.name, description = bonus.desc})
        end
        mon["BONUS ACTIONS"] = bonus_actions
    end

    -- Simple action lists (table-driven to reduce repetition)
    local simple_action_lists = {
        {json_field = "abilities", yaml_field = "TRAITS"},
        {json_field = "reactions", yaml_field = "REACTIONS"},
        {json_field = "legendaries", yaml_field = "LEGENDARY ACTIONS"},
        {json_field = "villains", yaml_field = "VILLAIN ACTIONS"}
    }
    for _, list_config in ipairs(simple_action_lists) do
        local json_list = json_mon[list_config.json_field]
        if json_list and #json_list > 0 then
            local items = {}
            for _, item in ipairs(json_list) do
                table.insert(items, {name = item.name, description = item.desc})
            end
            mon[list_config.yaml_field] = items
        end
    end

    -- ACTIONS
    if json_mon.actions and #json_mon.actions > 0 then
        local actions = {}
        local multiattack = nil
        for _, action in ipairs(json_mon.actions) do
            if action.name == "Multiattack" then
                multiattack = {name = action.name, description = action.desc}
            else
                local act = {name = action.name, description = action.desc}
                if action.atkbonus then
                    act["ATTACK BONUS"] = action.atkbonus
                end
                table.insert(actions, act)
            end
        end
        if multiattack then
            mon.MULTIATTACK = {multiattack}
        end
        if #actions > 0 then
            mon.ATTACKS = actions
        end
    end

    -- Assertions for fields that should have specific values
    if json_mon.hpCut and json_mon.hpCut ~= 1 then
        io.stderr:write("Error: hpCut is " .. tostring(json_mon.hpCut) .. ", expected 1\n")
        os.exit(1)
    end

    if json_mon.customSpeed ~= false and json_mon.customSpeed ~= nil then
        io.stderr:write("Error: customSpeed is " .. tostring(json_mon.customSpeed) .. ", expected false\n")
        os.exit(1)
    end

    if json_mon.specialdamage then
        local sd_type = type(json_mon.specialdamage)
        if sd_type == "table" and next(json_mon.specialdamage) ~= nil then
            io.stderr:write("Error: specialdamage is not empty\n")
            os.exit(1)
        elseif sd_type ~= "table" then
            io.stderr:write("Error: specialdamage is " .. sd_type .. ", expected empty table\n")
            os.exit(1)
        end
    end

    if json_mon.properties then
        if type(json_mon.properties) == "table" and #json_mon.properties > 0 then
            io.stderr:write("Error: properties is not an empty list\n")
            os.exit(1)
        end
    end

    -- Ignore fields we don't convert (presentation/UI/metadata)
    ignore(json_mon.doubleColumns)
    ignore(json_mon.hpCut)
    ignore(json_mon.isLegendary)
    ignore(json_mon.legendariesDescription)
    ignore(json_mon.paragon)
    ignore(json_mon.shieldBonus)
    ignore(json_mon.customSpeed)
    ignore(json_mon.specialdamage)
    ignore(json_mon.properties)
    ignore(json_mon.separationPoint)
    ignore(json_mon.dpr)  -- Using avgDMG instead
    ignore(json_mon.threatadj)  -- Already asserted to be 0

    return mon
end

-- Main program
local function main()
    local input_file = arg[1]

    if not input_file then
        io.stderr:write("Usage: " .. arg[0] .. " <input.monster>\n")
        os.exit(1)
    end

    -- Read JSON
    local f = io.open(input_file, "r")
    if not f then
        io.stderr:write("Error: Cannot open file: " .. input_file .. "\n")
        os.exit(1)
    end
    local json_text = f:read("*all")
    f:close()

    -- Remove trailing commas (common in JavaScript but invalid in JSON)
    -- Pattern: comma followed by optional whitespace and then closing bracket/brace
    json_text = json_text:gsub(",%s*([%]%}])", "%1")

    -- Parse JSON
    local ok, json_data = pcall(cjson.decode, json_text)
    if not ok then
        io.stderr:write("Error: Failed to parse JSON: " .. json_data .. "\n")
        os.exit(1)
    end

    -- Create tracking proxy for the JSON data
    local json_mon, original_json, accessed_keys = make_tracking_proxy(json_data)

    -- Convert to YAML structure
    local mon = convert_monster(json_mon)

    -- Check for unaccessed keys
    check_unaccessed_keys(original_json, accessed_keys, input_file)

    -- Output YAML
    local yaml_text = yaml.dump({mon})
    print(yaml_text)
end

main()
