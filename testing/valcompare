#!/bin/ksh
# valcompare — compare the validation verdicts of bin/charsheet vs bin/ocharsheet.
#
# Ephemeral migration aid.  For each YAML file named on the command line,
# run each script with -s (emit macros only; no PDF, no side effects) in
# the default non-strict mode and reduce the run to a verdict:
#       OK        exit 0, zero validation errors
#       FAIL:n    exit 0, n validation errors (counted from stderr)
#       CRASH     nonzero exit (parse error, Lua error, ...)
#
# The two scripts word their messages differently, so we compare verdicts,
# not text.  Both emit one "Validation error in <file>: ..." line per error
# on stderr, so n is just a line count.  A file is flagged (status != AGREE)
# when the pass/fail outcome differs (DIFFER), when both reject but with a
# different error count (COUNT), or when either script crashes (CRASH).
#
# Some differences are innocuous: a check that exists on only one side by
# design.  Innocuous messages (see cs_innocuous / ocs_innocuous below) are
# dropped before the verdict is computed, so a file whose only differences
# are innocuous reads AGREE.  With -v, every diverging row -- and every row
# where something was suppressed -- shows the actual messages, including the
# suppressed ones (prefixed "~").
#
# The report goes to stdout; progress/summary notes go to stderr; the
# script exits nonzero if any file diverged.

here=$(cd "$(dirname "$0")/.." && pwd)
cs=$here/bin/charsheet
ocs=$here/bin/ocharsheet

# charsheet is given a default CLASS so classless YAML files don't trip its
# "required key CLASS is missing" check.  ocharsheet has no -class option,
# so its own missing-CLASS message is treated as innocuous (see below).
cs_class=Fighter

# Innocuous differences: validation messages that legitimately appear on
# only one side, with no analog expected on the other.  Each entry is an
# extended regex (ERE) matched against the message text (the part after
# "Validation error in <file>: ").  Patterns in cs_innocuous are dropped
# from charsheet's messages; ocs_innocuous from ocharsheet's.
set -A cs_innocuous
set -A ocs_innocuous \
  'labeled with the unknown property "(components|material)"' \
  'must have either'

if [ $# -gt 0 ] && [ "$1" = -v ]; then verbose=true; shift; else verbose=false; fi

if [ $# -eq 0 ]; then
  print -u2 "usage: $0 [-v] file.yaml ..."
  exit 2
fi

# Build a single ERE alternation per side from its innocuous array (empty
# string when the array is empty, meaning "suppress nothing").
ere() {
  typeset out= p
  for p in "$@"; do
    if [ -n "$out" ]; then out="$out|$p"; else out="$p"; fi
  done
  print -r -- "$out"
}
cs_filter=$(ere "${cs_innocuous[@]}")
ocs_filter=$(ere "${ocs_innocuous[@]}")

# capture COMMAND... -> sets RC (exit code) and ERR (captured stderr).
capture() { ERR=$("$@" 2>&1 >/dev/null); RC=$?; }

# msgs_of TEXT -> the bare message bodies, one per line.
msgs_of() { printf '%s\n' "$1" | sed -n 's/^Validation error in [^:]*: //p'; }

# keep FILTER / drop FILTER -> stdin lines NOT / DO matching FILTER.
keep() { if [ -n "$1" ]; then grep -vE -- "$1"; else cat; fi; }
drop() { if [ -n "$1" ]; then grep -E  -- "$1"; else cat >/dev/null; fi; }

# verdict_of RC KEPT-MESSAGES -> OK | FAIL:n | CRASH
verdict_of() {
  if [ "$1" -ne 0 ]; then print CRASH; return; fi
  typeset n; n=$(printf '%s\n' "$2" | grep -c .)
  if [ "$n" -eq 0 ]; then print OK; else print "FAIL:$n"; fi
}

status=0
diverged=0
printf '%-7s %-45s %-10s %-10s\n' STATUS FILE charsheet ocharsheet
for f in "$@"; do
  capture "$cs" -class "$cs_class" -s "$f"; cs_rc=$RC;  cs_err=$ERR;  cs_all=$(msgs_of "$cs_err")
  capture "$ocs"                   -s "$f"; ocs_rc=$RC; ocs_err=$ERR; ocs_all=$(msgs_of "$ocs_err")

  cs_kept=$(printf  '%s\n' "$cs_all"  | keep "$cs_filter")
  cs_supp=$(printf  '%s\n' "$cs_all"  | drop "$cs_filter")
  ocs_kept=$(printf '%s\n' "$ocs_all" | keep "$ocs_filter")
  ocs_supp=$(printf '%s\n' "$ocs_all" | drop "$ocs_filter")

  a=$(verdict_of "$cs_rc"  "$cs_kept")
  b=$(verdict_of "$ocs_rc" "$ocs_kept")

  if   [ "$a" = CRASH ] || [ "$b" = CRASH ]; then st=CRASH
  elif [ "$a" = "$b" ];                      then st=AGREE
  elif [ "$a" = OK ] || [ "$b" = OK ];       then st=DIFFER
  else                                            st=COUNT
  fi
  if [ "$st" != AGREE ]; then status=1; diverged=$((diverged + 1)); fi
  printf '%-7s %-45s %-10s %-10s\n' "$st" "$(basename "$f")" "$a" "$b"

  if $verbose && { [ "$st" != AGREE ] || [ -n "$cs_supp$ocs_supp" ]; }; then
    # On a crash, show the raw stderr (likely a traceback); otherwise the
    # kept (non-innocuous) messages.  Suppressed messages follow, marked "~".
    if [ "$cs_rc" -ne 0 ]; then
      printf '%s\n' "$cs_err"  | grep . | sed 's/^/    charsheet ! /'
    else
      printf '%s\n' "$cs_kept" | grep . | sed 's/^/    charsheet : /'
    fi
    if [ "$ocs_rc" -ne 0 ]; then
      printf '%s\n' "$ocs_err"  | grep . | sed 's/^/    ocharsheet! /'
    else
      printf '%s\n' "$ocs_kept" | grep . | sed 's/^/    ocharsheet: /'
    fi
    printf '%s\n' "$cs_supp"  | grep . | sed 's/^/    ~cs suppressed : /'
    printf '%s\n' "$ocs_supp" | grep . | sed 's/^/    ~ocs suppressed: /'
  fi
done

print -u2 "valcompare: $diverged of $# file(s) diverged"
exit $status
